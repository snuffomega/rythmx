# rythmx — environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.

# ── Paths ──────────────────────────────────────
# Path to SoulSync's music_library.db (read-only mount in Docker)
SOULSYNC_DB=/data/soulsync/music_library.db

# Path to rythmx's own database
RYTHMX_DB=/data/cc/rythmx.db
# Upgrading from an older install? If you had CC_DB set, rename it to RYTHMX_DB above.
# The app reads RYTHMX_DB first, then falls back to CC_DB for one transition cycle.
# CC_DB=/data/cc/cc.db   ← legacy name — still works, but prefer RYTHMX_DB

# ── SoulSync Integration ─────────────────────────────────────────────────────
# Base URL of the running SoulSync container
SOULSYNC_URL=http://10.10.1.10:8009

# ── Last.fm ─────────────────────────────────────
# Get your API key at: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USERNAME=your_lastfm_username_here

# ── Plex ────────────────────────────────────────
# Your Plex server URL (e.g. http://10.10.1.10:32400)
PLEX_URL=http://your-plex-server:32400

# Get your token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your_plex_token_here

# Plex music library section name (default: Music)
# PLEX_MUSIC_SECTION=Music

# Library backend: soulsync (default) | plex | navidrome | jellyfin
# LIBRARY_BACKEND=soulsync

# ── Spotify (optional) ──────────────────────────
# Create an app at: https://developer.spotify.com/dashboard
# Only needed if you run SoulSync with a Spotify scan.
# Without Spotify, rythmx uses iTunes + Deezer for release data.
# SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── Fanart.tv (optional) ─────────────────────────
# Free API key — register at: https://fanart.tv/get-an-api-key/
# When set: artist tiles show real band photos via Fanart.tv + MusicBrainz
# When not set: artist tiles fall back to iTunes album art (still looks good)
# FANART_API_KEY=your_fanart_api_key_here

# ── Flask ───────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=8009
FLASK_DEBUG=false
# LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR (default: INFO, or DEBUG when FLASK_DEBUG=true)

# ── Cruise Control defaults ─────────────────────
# These set the initial defaults before any UI-saved configuration exists.
# Once you save settings in the UI they are stored in rythmx.db and take precedence.
CYCLE_HOURS=24
MAX_PER_CYCLE=10
MIN_LISTENS=5
LOOKBACK_DAYS=90

# Upgrading from an older install? The old CC_-prefixed env vars still work as fallbacks:
# CC_CYCLE_HOURS, CC_MAX_PER_CYCLE, CC_MIN_LISTENS, CC_LOOKBACK_DAYS
# Rename them to the unprefixed names above and remove the CC_ versions.
