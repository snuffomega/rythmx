# rythmx — environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.

# ── Rythmx Database ──────────────────────────────────────────────────────────
# Path to Rythmx Database — the permanent store for library, releases, history, and settings.
RYTHMX_DB=/data/rythmx/rythmx.db

# ── Last.fm ──────────────────────────────────────────────────────────────────
# Required — used for listening history, taste scoring, and top-artist feeds.
# Get your API key at: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USERNAME=your_lastfm_username_here

# ── Library Platform ──────────────────────────────────────────────────────────
# Which media server populates your library (lib_artists / lib_albums / lib_tracks in rythmx.db).
# plex      — sync from Plex on demand via the Rythmx UI; library stored in rythmx.db.
# navidrome | jellyfin — stubs; not yet implemented.
# SoulSync is an enrichment API, not a platform — do not set LIBRARY_PLATFORM=soulsync.
LIBRARY_PLATFORM=plex

# ── Plex ──────────────────────────────────────────────────────────────────────
# Required when LIBRARY_PLATFORM=plex.
# Your Plex server URL (e.g. http://10.10.1.10:32400)
PLEX_URL=http://your-plex-server:32400
# Get your token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your_plex_token_here
# Plex music library name as it appears in Plex (default: Music)
# PLEX_MUSIC_SECTION=Music

# ── SoulSync Enrichment API ───────────────────────────────────────────────────
# SoulSync is an enrichment API source (not a library platform).
# SOULSYNC_DB is read-only — rythmx reads enriched IDs from it for identity resolution.
# Path to SoulSync's music_library.db (read-only mount in Docker)
# SOULSYNC_DB=/data/soulsync/music_library.db
# Base URL of the running SoulSync container (used for download queue submission)
# SOULSYNC_URL=http://10.10.1.10:8009

# ── Spotify (optional) ────────────────────────────────────────────────────────
# Adds Spotify as a release-lookup provider (highest quality release metadata).
# Without Spotify, rythmx uses iTunes + Deezer for release data — still works well.
# Create an app at: https://developer.spotify.com/dashboard
# SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# SPOTIFY_RATE_LIMIT_RPM=100   # Requests per minute ceiling. Lower if you hit 429s.

# ── Fanart.tv (optional) ──────────────────────────────────────────────────────
# Free API key — register at: https://fanart.tv/get-an-api-key/
# When set: artist tiles show real band photos via Fanart.tv + MusicBrainz.
# When not set: artist tiles fall back to iTunes album art (still looks good).
# FANART_API_KEY=your_fanart_api_key_here

# ── Music Directory (optional) ────────────────────────────────────────────
# Absolute path to your music files — the same directory Plex reads from.
# Enables: local artwork fallback (folder.jpg / cover.png), and future
# file-aware features (tag enrichment, embedded artwork, codec/bitrate info).
# When not set, all file-aware features are silently skipped — no errors.
# Docker: mount your music folder read-only in docker-compose.yml, e.g.:
#   - /mnt/user/data/media/music:/music:ro
# Then set:
# MUSIC_DIR=/music

# ── Server ────────────────────────────────────────────────────────────────────
RYTHMX_HOST=0.0.0.0
RYTHMX_PORT=8009
RYTHMX_DEBUG=false
# LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR (default: INFO, or DEBUG when RYTHMX_DEBUG=true)
# Deprecated: FLASK_HOST / FLASK_PORT / FLASK_DEBUG still work but log a warning.

# ── Cruise Control defaults ───────────────────────────────────────────────────
# These set the initial defaults before any UI-saved configuration exists.
# Once you save settings in the UI they are stored in rythmx.db and take precedence.
CYCLE_HOURS=24
MAX_PER_CYCLE=10
MIN_LISTENS=5
LOOKBACK_DAYS=90

